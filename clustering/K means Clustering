      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.datasets import make_blobs\n",
        "from sklearn.cluster import KMeans\n",
        "\n",
        "X, true_labels = make_blobs(n_samples=120, n_features=3, centers=4, cluster_std=1.5, random_state=42)\n",
        "X.head\n",
        "\n",
        "kmeans = KMeans(n_clusters=4, random_state=42, n_init='auto')\n",
        "\n",
        "predicted_labels = kmeans.fit_predict(X)\n",
        "centroids = kmeans.cluster_centers_\n",
        "\n",
        "fig = plt.figure(figsize=(10, 7))\n",
        "ax = fig.add_subplot(111, projection='3d')\n",
        "\n",
        "scatter = ax.scatter(X[:, 0], X[:, 1], X[:, 2],\n",
        "                     c=predicted_labels, cmap='viridis',\n",
        "                     s=50, alpha=0.7, edgecolors='w')\n",
        "\n",
        "ax.scatter(centroids[:, 0], centroids[:, 1], centroids[:, 2],\n",
        "           c='red', marker='X', s=200, label='Centroids', linewidths=3)\n",
        "\n",
        "ax.set_title(\"K-Means Clustering on 3D Random Data\")\n",
        "ax.set_xlabel(\"Feature 1\")\n",
        "ax.set_ylabel(\"Feature 2\")\n",
        "ax.set_zlabel(\"Feature 3\")\n",
        "plt.legend()\n",
        "plt.show()"
